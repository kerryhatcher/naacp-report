---
import Layout from '../../layouts/Layout.astro'
import { getCounties, getCounty, type CountyDetail } from '../../lib/data'
import { href } from '../../lib/url'

export async function getStaticPaths() {
  const counties = await getCounties()
  return Promise.all(
    counties.map(async ({ slug }) => ({
      params: { slug },
      props: { county: await getCounty(slug) },
    })),
  )
}

interface Props {
  county: CountyDetail
}

const { county } = Astro.props

const facts = [
  { label: 'Board members', value: county.members ?? '—' },
  { label: 'Selection method', value: county.selection_method ?? '—' },
  { label: 'Meets', value: county.meeting_schedule ?? '—' },
]
---

<Layout
  title={`${county.name} County Board of Elections`}
  description={`How the ${county.name} County Board of Elections is composed, selected, and when it meets.`}
>
  <article class="reveal max-w-3xl">
    <a href={href('/counties')} class="kicker text-accent transition-opacity hover:opacity-70">
      ← County Boards Directory
    </a>
    <h1 class="display-opt mt-4 text-4xl font-semibold leading-tight tracking-tight sm:text-6xl">
      {county.name} County
    </h1>
    <p class="mt-2 font-sans text-sm text-ink-2">Board of Elections</p>

    <dl class="mt-10 grid grid-cols-1 gap-x-8 gap-y-6 sm:grid-cols-3">
      {
        facts.map(({ label, value }) => (
          <div class="border-t-2 border-ink pt-3">
            <dt class="kicker text-ink-2">{label}</dt>
            <dd class="mt-2 font-serif text-xl capitalize">{value}</dd>
          </div>
        ))
      }
    </dl>

    <div class="prose-report prose mt-10 max-w-none" set:html={county.body_html} />
  </article>
</Layout>

---
import { getCounties } from '../lib/data'
import { href } from '../lib/url'

const counties = await getCounties()
---

<table class="table-report">
  <thead>
    <tr>
      <th>County</th>
      <th class="num">Members</th>
      <th>Selection method</th>
      <th class="hidden sm:table-cell"><span class="sr-only">View</span></th>
    </tr>
  </thead>
  <tbody>
    {
      counties.map((county) => (
        <tr>
          <td>
            <a
              class="font-serif text-base font-semibold text-ink underline decoration-rule underline-offset-4 transition-colors hover:text-accent hover:decoration-accent"
              href={href(`/counties/${county.slug}`)}
            >
              {county.name}
            </a>
          </td>
          <td class="num">{county.members ?? '—'}</td>
          <td class="capitalize">{county.selection_method ?? '—'}</td>
          <td class="hidden text-right text-accent sm:table-cell" aria-hidden="true">→</td>
        </tr>
      ))
    }
  </tbody>
</table>

---
import '../styles/global.css'
import { href } from '../lib/url'

interface Props {
  title: string
  description?: string
}

const {
  title,
  description = 'An independent investigation of election administration, turnout, and voter demographics across Georgia’s 159 counties.',
} = Astro.props

const navLinks = [
  { to: href('/counties'), label: 'County Boards' },
  { to: href('/turnout'), label: 'Turnout' },
  { to: href('/demographics'), label: 'Demographics' },
]
const current = Astro.url.pathname
const isHome = current === href('/') || current === `${href('/')}/`.replace('//', '/')
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href={href('/favicon.svg')} />
    <title>{title} · NAACP Georgia Elections Report</title>
  </head>
  <body class="min-h-screen">
    <a
      href="#main"
      class="kicker absolute left-4 top-2 -translate-y-16 bg-accent px-3 py-2 text-accent-contrast transition-transform focus:translate-y-0"
    >
      Skip to content
    </a>

    <!-- Preview banner: this build is a design test with sample data. -->
    <div class="bg-accent text-accent-contrast">
      <p class="kicker mx-auto max-w-6xl px-4 py-2 text-center sm:px-6">
        Design preview — not published. Figures on this site are sample data, not findings.
      </p>
    </div>

    <header class="border-b border-rule-strong">
      <div class="mx-auto max-w-6xl px-4 sm:px-6">
        <div class="flex items-baseline justify-between gap-4 pt-5 text-ink-2">
          <p class="kicker">An independent investigation</p>
          <p class="kicker hidden sm:block">Georgia · 2026</p>
        </div>

        <div class="pb-5 pt-3">
          {isHome ? (
            <span class="display-opt block text-4xl font-semibold leading-none tracking-tight sm:text-5xl">
              Georgia Elections Report
            </span>
          ) : (
            <a
              href={href('/')}
              class="display-opt block text-4xl font-semibold leading-none tracking-tight transition-colors hover:text-accent sm:text-5xl"
            >
              Georgia Elections Report
            </a>
          )}
          <p class="mt-2 font-sans text-xs text-ink-2">Commissioned by the NAACP</p>
        </div>
      </div>

      <nav class="border-t border-rule">
        <div class="mx-auto flex max-w-6xl gap-6 overflow-x-auto px-4 sm:gap-8 sm:px-6">
          {
            navLinks.map(({ to, label }) => {
              const active = current.startsWith(to)
              return (
                <a
                  href={to}
                  aria-current={active ? 'page' : undefined}
                  class:list={[
                    'kicker whitespace-nowrap border-b-2 py-3 transition-colors',
                    active
                      ? 'border-accent text-accent'
                      : 'border-transparent text-ink hover:border-rule-strong hover:text-accent',
                  ]}
                >
                  {label}
                </a>
              )
            })
          }
        </div>
      </nav>
    </header>

    <main id="main" class="mx-auto max-w-6xl px-4 py-10 sm:px-6 sm:py-14">
      <slot />
    </main>

    <footer class="mt-16 border-t-2 border-ink">
      <div class="mx-auto grid max-w-6xl gap-10 px-4 py-10 sm:grid-cols-3 sm:px-6">
        <div>
          <p class="kicker text-ink-2">About</p>
          <p class="mt-3 font-sans text-sm leading-relaxed text-ink-2">
            A report on election administration in Georgia: the 159 county boards
            that run its elections, turnout in every 2026 election, and the
            demographics of the registered electorate.
          </p>
        </div>
        <div>
          <p class="kicker text-ink-2">Sources</p>
          <p class="mt-3 font-sans text-sm leading-relaxed text-ink-2">
            Georgia Secretary of State elections division, county board minutes
            and agendas, local acts of the General Assembly, and Open Records
            Act requests (O.C.G.A. § 50-18-70).
          </p>
        </div>
        <div>
          <p class="kicker text-ink-2">Colophon</p>
          <p class="mt-3 font-sans text-sm leading-relaxed text-ink-2">
            Built from public records. Commissioned by the NAACP; the analysis
            and any errors are the authors&rsquo; own.
          </p>
        </div>
      </div>
    </footer>
  </body>
</html>
